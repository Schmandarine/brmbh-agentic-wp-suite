# Production environment template.
# Copy to production.env (gitignored) and fill in your values.
#
# Usage: source tools/env/production.env && ./tools/deploy.sh
#        source tools/env/production.env && ./tools/db-pull.sh
#
# Note: CANONICAL_ENV=remote here blocks db-push by default — production DB is
# the source of truth post-launch. db-pull (remote → local) stays allowed.

export SSH_TARGET="deploy@example.com"   # or an alias from ~/.ssh/config
export REMOTE_WP_PATH="/var/www/html"     # WP root on server (contains wp-config.php)
export REMOTE_URL="https://example.com"
export REMOTE_THEME="brmbh-agentic-wp-suite"

export LOCAL_URL="http://example.local"
export LOCAL_THEME="brmbh-agentic-wp-suite"
export LOCAL_WP_CLI="wp"

export CANONICAL_ENV="remote"
