# Staging environment template.
# Copy to staging.env (gitignored) and fill in your values.
#
# Usage: source tools/env/staging.env && ./tools/deploy.sh
#        source tools/env/staging.env && ./tools/db-push.sh

export SSH_TARGET="deploy@staging.example.com"   # or an alias from ~/.ssh/config
export REMOTE_WP_PATH="/var/www/staging"          # WP root on server (contains wp-config.php)
export REMOTE_URL="https://staging.example.com"
export REMOTE_THEME="brmbh-agentic-wp-suite"

export LOCAL_URL="http://example.local"
export LOCAL_THEME="brmbh-agentic-wp-suite"
# Set to "localwp" when using Local by Flywheel on macOS; defaults to "wp".
export LOCAL_WP_CLI="wp"

# Source-of-truth guard for db-push:
#   local  = local dev is canonical, db-push to remote is allowed (pre-launch)
#   remote = remote is canonical, db-push is BLOCKED (flip after launch)
export CANONICAL_ENV="local"
