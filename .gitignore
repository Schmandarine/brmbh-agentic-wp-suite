# Dependencies
node_modules/

# Build output (generated by `npm run build`)
assets/dist/

# Local project config (Figma keys, tokens) — copy from the .example
.brmbh-config.json

# Environment files for deploy/DB-sync (server hosts + paths) — templates only are tracked
tools/env/*.env
!tools/env/*.example

# OS / editor cruft
.DS_Store
*.log
npm-debug.log*

# Local WP-CLI / sandbox artifacts
.debug-screenshots/
