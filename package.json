{
  "name": "brmbh-agentic-wp-suite",
  "version": "0.1.0",
  "description": "Agentic WordPress starter theme — Bootstrap 5 + Gutenberg + ACF block factory with agent-agnostic skills.",
  "license": "GPL-2.0-or-later",
  "author": "Jan Brombach",
  "homepage": "https://github.com/Schmandarine/brmbh-agentic-wp-suite",
  "repository": {
    "type": "git",
    "url": "https://github.com/Schmandarine/brmbh-agentic-wp-suite.git"
  },
  "private": false,
  "scripts": {
    "build:js": "webpack --config webpack.config.js",
    "build:css": "./tools/sass-with-theme-flags.sh assets/src/scss/style.scss assets/dist/css/style.css --style=compressed --source-map && ./tools/sass-with-theme-flags.sh assets/src/scss/custom-bootstrap.scss assets/dist/css/custom-bootstrap.css --style=compressed --source-map",
    "build": "npm run build:js && npm run build:css",
    "watch:css": "./tools/sass-with-theme-flags.sh assets/src/scss/style.scss:assets/dist/css/style.css assets/src/scss/custom-bootstrap.scss:assets/dist/css/custom-bootstrap.css --watch --poll --style=compressed --source-map",
    "watch:js": "webpack --config webpack.config.js --watch",
    "watch": "concurrently -n scss,js -c cyan,magenta \"npm run watch:css\" \"npm run watch:js\""
  },
  "devDependencies": {
    "@babel/core": "^7.15.0",
    "@babel/preset-env": "^7.15.0",
    "babel-loader": "^8.2.2",
    "concurrently": "^9.2.1",
    "sass": "^1.69.0",
    "webpack": "^5.51.1",
    "webpack-cli": "^4.8.0"
  },
  "dependencies": {
    "bootstrap": "^5.3.0",
    "gsap": "^3.14.2"
  }
}
